# Email of the source account (the current owner)
SOURCE_EMAIL=your-source@gmail.com

# Email of the target account (the new owner)
TARGET_EMAIL=your-target@gmail.com

# Remove source account access after ownership transfer (1 = yes, 0 = no)
REMOVE_SOURCE_ACCESS=0

# Start transferring while pages are still being fetched (1 = yes, 0 = no)
# In stream mode the script sends the largest seen-so-far item after each page,
# then finishes the remaining items in global size order.
STREAM=0
